# Bright Data SERP API
# Sign up at https://brightdata.com and get your API token
BRIGHT_DATA_API_TOKEN=your_bright_data_api_token_here

# Bright Data SERP Zone name (check your dashboard)
BRIGHT_DATA_SERP_ZONE=serp_api1

# OpenAI API (OPTIONAL — for LLM-powered query expansion)
# Without this, rule-based expansion is used instead
OPENAI_API_KEY=
