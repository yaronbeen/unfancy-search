# Bright Data SERP API
# Sign up at https://brightdata.com and get your API token
BRIGHT_DATA_API_TOKEN=your_bright_data_api_token_here

# Bright Data SERP Zone name (check your dashboard)
BRIGHT_DATA_SERP_ZONE=serp_api1

# Anthropic API (required for LLM-powered query expansion)
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Bright Data Datasets API (OPTIONAL — for baseline comparison)
# Create a Web Scraper (SERP type) in your Bright Data dashboard
# and paste its dataset ID here to enable baseline vs live comparison.
# Default: gd_l1viktl72bvl7bjuj0 (standard Google Search SERP dataset)
BRIGHT_DATA_DATASET_ID=
